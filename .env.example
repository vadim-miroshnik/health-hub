# Fitbit OAuth2 (Personal app at dev.fitbit.com)
# OPTIONAL — Fitbit Web API is deprecated Sept 2026 and new app registrations
# are closed. Leave blank to run without the Fitbit collector; the Health
# Connect ingest server + CPAP/O2Ring sources continue to work.
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Paths
DB_PATH=data/health.db
RAW_DATA_DIR=data/raw
TOKENS_PATH=tokens.json

# CPAP-AutoSync — directory where AirSense 10 SD data is synced to
CPAP_DATA_DIR=/path/to/cpap/data

# O2Ring — directory for CSV exports from ViHealth (phase 1)
O2RING_DATA_DIR=/path/to/o2ring/data

# Health Connect Ingest server (phase 10)
# Generate strong token: python -c "import secrets; print(secrets.token_urlsafe(32))"
HC_INGEST_AUTH_TOKEN=
HC_INGEST_PORT=8765
HC_INGEST_HOST=0.0.0.0

# MCP server (remote access over SSE — set MCP_TRANSPORT=stdio for Claude Desktop locally)
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8766

# Container timezone — cron schedules use this. Set to your locale.
TZ=Europe/Moscow
